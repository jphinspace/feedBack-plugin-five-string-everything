{
    "id": "chart_retuner",
    "name": "Chart Retuner",
    "version": "0.5.0",
    "script": "screen.js",
    "scriptType": "module",
    "minHost": "0.3.0-alpha.1",
    "standards": ["capability-pipelines.v1"],
    "capabilities": {
        "chart-transform": {
            "roles": ["provider"],
            "operations": ["chart.transform"],
            "mode": "active",
            "compatibility": "degrade-noop",
            "ownership": "multi-provider",
            "safety": "safe",
            "description": "Remaps the difficulty-filtered chart to a target tuning before render and scoring via the core chart-transform domain (feedBack#952)."
        }
    },
    "styles": "assets/plugin.css",
    "settings": { "html": "settings.html", "category": "graphics" }
}
